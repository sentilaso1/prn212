@page "/Profile"
@model WorkFlowPro.Pages.ProfileModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hồ sơ cá nhân";
    var hasEvaluationData = Model.Profile?.AvgScore > 0 || (Model.Profile?.TaskHistory.Any(t => t.Score.HasValue) ?? false);
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1 class="h3 mb-3">Member profile</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}
else if (Model.WorkspaceId is null)
{
    <div class="alert alert-info">
        Bạn chưa chọn workspace. Hồ sơ sẽ hiển thị thông tin cơ bản.
    </div>

    @if (Model.BasicProfile is null)
    {
        <div class="alert alert-danger">Không tải được profile.</div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        @if (!string.IsNullOrWhiteSpace(Model.BasicProfile.AvatarUrl))
                        {
                            <img src="@Model.BasicProfile.AvatarUrl" alt="avatar" class="rounded-circle mb-3" style="width:120px;height:120px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary-subtle d-inline-flex align-items-center justify-content-center mb-3" style="width:120px;height:120px;">
                                <span class="fs-2 text-muted">@(Model.BasicProfile.FullName.Length > 0 ? Model.BasicProfile.FullName[0] : '?')</span>
                            </div>
                        }
                        <h2 class="h5 mb-1">@Model.BasicProfile.FullName</h2>
                        <p class="text-muted small mb-0">@Model.BasicProfile.Email</p>
                    </div>
                </div>
            </div>
        </div>
    }
}
else if (Model.Profile is null)
{
    <div class="alert alert-danger">Không tải được profile.</div>
}
else
{
    @if (Model.Profile.IsPlatformAdminReadOnlyView)
    {
        <div class="alert alert-secondary py-2 small mb-3">
            Bạn đang xem hồ sơ thành viên ở chế độ quản trị — chỉ xem, không chỉnh sửa.
            @if (Model.WorkspaceId.HasValue)
            {
                <span>· <a href="/Reports/Dashboard?workspaceId=@Model.WorkspaceId.Value.ToString("D")">← Báo cáo KPI đơn vị</a></span>
            }
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    @if (!string.IsNullOrWhiteSpace(Model.Profile.AvatarUrl))
                    {
                        <img src="@Model.Profile.AvatarUrl" alt="avatar" class="rounded-circle mb-3" style="width:120px;height:120px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-secondary-subtle d-inline-flex align-items-center justify-content-center mb-3" style="width:120px;height:120px;">
                            <span class="fs-2 text-muted">@(Model.Profile.FullName.Length > 0 ? Model.Profile.FullName[0] : '?')</span>
                        </div>
                    }
                    <h2 class="h5 mb-1">@Model.Profile.FullName</h2>
                    <p class="text-muted small mb-0">@Model.Profile.Email</p>
                    @if (!string.IsNullOrWhiteSpace(Model.Profile.SubRole))
                    {
                        <p class="mt-2 mb-0"><span class="badge bg-light text-dark border">@Model.Profile.SubRole</span></p>
                    }
                    <p class="small text-muted mt-2 mb-0">Vai trò workspace: @Model.Profile.WorkspaceRole</p>
                </div>
            </div>

            @if (Model.Profile.CanEditProfile)
            {
                <div class="card shadow-sm mt-3">
                    <div class="card-header">Chỉnh sửa thông tin cá nhân</div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="UpdateProfile" enctype="multipart/form-data" class="needs-validation">
                            <input type="hidden" asp-for="Input.TargetUserId" />
                            <div asp-validation-summary="ModelOnly" class="text-danger small" role="alert"></div>
                            <div class="mb-3">
                                <label asp-for="Input.FullName" class="form-label">Họ tên</label>
                                <input asp-for="Input.FullName" class="form-control" />
                                <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Input.AvatarFile" class="form-label">Avatar (JPG/PNG, tối đa 2MB)</label>
                                <input asp-for="Input.AvatarFile" class="form-control" type="file" accept="image/jpeg,image/png,.jpg,.jpeg,.png" />
                                <span asp-validation-for="Input.AvatarFile" class="text-danger small"></span>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
                        </form>
                    </div>
                </div>
            }

            @if (Model.Profile.CanEditLevelOrSubRole)
            {
                <div class="card shadow-sm mt-3 border-primary">
                    <div class="card-header bg-primary text-white">PM — Propose Level / SubRole Change</div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="UpdatePm" id="pmUpdateForm">
                            <input type="hidden" asp-for="PmInput.TargetUserId" />
                            <div asp-validation-summary="ModelOnly" class="text-danger small" role="alert"></div>
                            <div class="mb-3">
                                <label asp-for="PmInput.Level" class="form-label">Proposed Level</label>
                                <select asp-for="PmInput.Level" class="form-select" asp-items="Html.GetEnumSelectList<WorkFlowPro.Data.MemberLevel>()"></select>
                            </div>
                            <div class="mb-3" id="levelReasonContainer" style="display: none;">
                                <label asp-for="PmInput.LevelChangeReason" class="form-label">Reason <span class="text-danger">*</span></label>
                                <textarea asp-for="PmInput.LevelChangeReason" class="form-control" rows="2" maxlength="500" placeholder="Vui lòng nhập lý do đề xuất thay đổi Level..."></textarea>
                                <span asp-validation-for="PmInput.LevelChangeReason" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="PmInput.SubRole" class="form-label">Proposed SubRole</label>
                                <input asp-for="PmInput.SubRole" class="form-control" list="subrole-list" placeholder="BA, DEV, Designer, QA..." maxlength="100" />
                                <datalist id="subrole-list">
                                    <option value="BA"></option>
                                    <option value="DEV"></option>
                                    <option value="Designer"></option>
                                    <option value="QA"></option>
                                    <option value="Tester"></option>
                                </datalist>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm w-100">Propose Change</button>
                        </form>
                    </div>
                </div>
            }
        </div>
        <div class="col-lg-8">
            <partial name="_MemberStats" model="Model.Profile" />
            <partial name="_TaskHistory30Days" model="Model.Profile.TaskHistory" />
        </div>
    </div>
}

@if (Model.ShowToast)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1090;">
        <div id="profileSuccessToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">@Model.ToastMessage</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (Model.ShowToast)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const el = document.getElementById('profileSuccessToast');
                if (el && typeof bootstrap !== 'undefined' && bootstrap.Toast) {
                    const toast = new bootstrap.Toast(el, { delay: 4000 });
                    toast.show();
                }

                const levelSelect = document.getElementById('PmInput_Level');
                const reasonContainer = document.getElementById('levelReasonContainer');
                const reasonInput = document.getElementById('PmInput_LevelChangeReason');
                const originalLevelValue = '@((int)(Model.Profile?.Level ?? WorkFlowPro.Data.MemberLevel.Junior))';
                const hasEvaluationData = @(hasEvaluationData ? "true" : "false");
                const pmForm = document.getElementById('pmUpdateForm');

                function updateReasonVisibility() {
                    if (levelSelect.value !== originalLevelValue) {
                        reasonContainer.style.display = 'block';
                        reasonInput.required = true;
                    } else {
                        reasonContainer.style.display = 'none';
                        reasonInput.required = false;
                    }
                }

                if (levelSelect && reasonContainer && reasonInput) {
                    levelSelect.addEventListener('change', updateReasonVisibility);
                    updateReasonVisibility();
                }

                if (pmForm) {
                    pmForm.addEventListener('submit', function (e) {
                        const isLevelChange = levelSelect.value !== originalLevelValue;
                        if (isLevelChange) {
                            if (!reasonInput.value.trim()) {
                                alert('Vui lòng nhập lý do đề xuất thay đổi Level.');
                                e.preventDefault();
                                return;
                            }
                            if (!hasEvaluationData) {
                                if (!confirm('Thành viên này chưa có dữ liệu đánh giá task. Bạn có chắc chắn muốn gửi đề xuất thay đổi Level không?')) {
                                    e.preventDefault();
                                    return;
                                }
                            } else {
                                if (!confirm('Xác nhận gửi đề xuất thay đổi Level cho thành viên này tới Admin?')) {
                                    e.preventDefault();
                                    return;
                                }
                            }
                        } else {
                            if (!confirm('Xác nhận cập nhật SubRole cho thành viên này?')) {
                                e.preventDefault();
                                return;
                            }
                        }
                    });
                }
            });
        </script>
    }
}
