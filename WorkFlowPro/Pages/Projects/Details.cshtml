@page "/Projects/Details/{projectId:guid}"
@model WorkFlowPro.Pages.Projects.DetailsModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Project details";
    var wsQ = Model.CurrentWorkspaceId is not null ? $"?workspaceId={Model.CurrentWorkspaceId.Value:D}" : "";
    var wsAmp = Model.CurrentWorkspaceId is not null ? $"&workspaceId={Model.CurrentWorkspaceId.Value:D}" : "";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Project Details</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

@if (Model.Project is not null)
{
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <div>
                    <h4 class="card-title">@Model.Project.Name</h4>
                    @if (Model.Project.Status == WorkFlowPro.Data.ProjectStatus.Archived)
                    {
                        <span class="badge bg-secondary">Archived</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Active</span>
                    }
                </div>
                <div>
                    <span class="badge bg-light text-dark border" style="background:@(Model.Project.Color ?? "#FFFFFF") !important; border-color:#ddd;">
                        Color: @Model.Project.Color
                    </span>
                </div>
            </div>

            <dl class="row mt-3">
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Project.Description</dd>

                <dt class="col-sm-3">Start</dt>
                <dd class="col-sm-9">@Model.Project.StartDateUtc?.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">End</dt>
                <dd class="col-sm-9">@Model.Project.EndDateUtc?.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@Model.Project.CreatedAtUtc.ToString("yyyy-MM-dd")</dd>
            </dl>

            <hr />
            <h5>Task Management</h5>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary" href="/board?projectId=@(Model.Project.Id)@(wsAmp)">
                    Kanban Board
                </a>
                <a class="btn btn-outline-primary" href="/tasks/list?projectId=@(Model.Project.Id)@(wsAmp)">
                    Task List
                </a>
                @if (Model.CanManage)
                {
                    <a class="btn btn-success" href="/Tasks/Create?projectId=@(Model.Project.Id)@(wsAmp)">
                        + Tạo Task
                    </a>
                }
            </div>

            <hr />
            @if (Model.CanManage)
            {
                <div class="d-flex gap-2">
                    <a class="btn btn-sm btn-outline-primary" href="/Projects/Settings/@(Model.Project.Id)@(wsQ)">Settings</a>
                    <a class="btn btn-sm btn-outline-danger" href="/Projects/Delete/@(Model.Project.Id)@(wsQ)">Delete</a>
                </div>
            }
            else
            {
                <div class="alert alert-info mt-3" role="alert">
                    Bạn đang có quyền xem dự án (read-only). Chỉ PM mới có quyền Settings/Delete.
                </div>
            }
        </div>
    </div>
}
