@page "/Projects/Details/{projectId:guid}"
@model WorkFlowPro.Pages.Projects.DetailsModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chi tiết dự án";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1 class="h3 mb-1">Chi tiết dự án</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

@if (Model.Project is not null)
{
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <div>
                    <h4 class="card-title">@Model.Project.Name</h4>
                    @switch (Model.Project.Status)
                    {
                        case WorkFlowPro.Data.ProjectStatus.PendingApproval:
                            <span class="badge bg-warning text-dark">Chờ duyệt</span>
                            break;
                        case WorkFlowPro.Data.ProjectStatus.Active:
                            <span class="badge bg-success">Đang hoạt động</span>
                            break;
                        case WorkFlowPro.Data.ProjectStatus.Archived:
                            <span class="badge bg-secondary">Đã lưu trữ</span>
                            break;
                        case WorkFlowPro.Data.ProjectStatus.Rejected:
                            <span class="badge bg-danger">Bị từ chối</span>
                            break;
                    }
                </div>
                <div>
                    <span class="badge text-bg-light border" style="background:@(Model.Project.Color ?? "#FFFFFF"); border-color:#ddd;">
                        Color: @Model.Project.Color
                    </span>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-3">
                @if (Model.Project.Status == WorkFlowPro.Data.ProjectStatus.Active || Model.Project.Status == WorkFlowPro.Data.ProjectStatus.Archived)
                {
                    <a class="btn btn-sm btn-outline-primary" href="/board?projectId=@Model.Project.Id&workspaceId=@Model.CurrentWorkspaceId">Kanban</a>
                    @if (Model.CurrentWorkspaceId is { } wid)
                    {
                        <a class="btn btn-sm btn-outline-primary" href="/tasks/list?projectId=@Model.Project.Id&workspaceId=@wid">Danh sách task </a>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-outline-primary" href="/tasks/list?projectId=@Model.Project.Id">Danh sách task </a>
                    }
                    @if (Model.CanManage && Model.Project.Status == WorkFlowPro.Data.ProjectStatus.Active)
                    {
                        <a class="btn btn-sm btn-primary" href="/Tasks/Create?projectId=@Model.Project.Id&workspaceId=@Model.CurrentWorkspaceId">+ Tạo task</a>
                    }
                }
                else
                {
                    <button class="btn btn-sm btn-outline-primary" disabled title="Chờ Admin duyệt">Kanban</button>
                    <button class="btn btn-sm btn-outline-primary" disabled title="Chờ Admin duyệt">Danh sách task</button>
                    @if (Model.CanManage)
                    {
                        <button class="btn btn-sm btn-primary" disabled title="Chờ Admin duyệt">+ Tạo task</button>
                    }
                }
            </div>

            <dl class="row mt-3">
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Project.Description</dd>

                <dt class="col-sm-3">Start</dt>
                <dd class="col-sm-9">@Model.Project.StartDateUtc?.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">End</dt>
                <dd class="col-sm-9">@Model.Project.EndDateUtc?.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@Model.Project.CreatedAtUtc.ToString("yyyy-MM-dd")</dd>
            </dl>

            @if (Model.CanManage)
            {
                <div class="d-flex gap-2 mt-3">
                    <a class="btn btn-sm btn-outline-primary" href="/Projects/Settings/@Model.Project.Id?workspaceId=@Model.CurrentWorkspaceId">Settings</a>
                    <a class="btn btn-sm btn-outline-danger" href="/Projects/Delete/@Model.Project.Id?workspaceId=@Model.CurrentWorkspaceId">Delete</a>
                </div>
            }
            else
            {
                <div class="alert alert-info mt-3" role="alert">
                    Bạn đang có quyền xem dự án (read-only). Chỉ PM mới có quyền Settings/Delete.
                </div>
            }
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                @if (Model.CanManage)
                {
                    <a class="btn btn-sm btn-outline-primary" href="/Roles" title="Quản lý thành viên và vai trò trong đơn vị">
                        Quản lý thành viên &amp; role
                    </a>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th>Tên hiển thị</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Sub-role</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var m in Model.WorkspaceMembers)
                    {
                        <tr>
                            <td class="fw-medium">@m.DisplayName</td>
                            <td class="small">@(m.Email ?? "—")</td>
                            <td><span class="badge bg-secondary bg-opacity-25 text-dark">@m.Role</span></td>
                            <td class="small">@(string.IsNullOrWhiteSpace(m.SubRole) ? "—" : m.SubRole)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

