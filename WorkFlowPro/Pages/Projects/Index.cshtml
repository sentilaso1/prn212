@page "/Projects"
@model WorkFlowPro.Pages.Projects.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Projects";
    var wsQ = Model.CurrentWorkspaceId is not null ? $"?workspaceId={Model.CurrentWorkspaceId.Value:D}" : "";
    var wsAmp = Model.CurrentWorkspaceId is not null ? $"&workspaceId={Model.CurrentWorkspaceId.Value:D}" : "";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Projects</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted">
        Workspace Projects
    </div>
    @if (Model.IsPm)
    {
        <a class="btn btn-primary" href="/Projects/Create@(wsQ)">+ Tạo dự án</a>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

@if (Model.Projects.Count == 0)
{
    <div class="alert alert-info">Chưa có dự án trong workspace hiện tại.</div>
}
else
{
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Color</th>
            <th>Created</th>
            <th style="width: 300px;">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Projects)
        {
            <tr>
                <td>@p.Name</td>
                <td>
                    @if (p.Status == WorkFlowPro.Data.ProjectStatus.Archived)
                    {
                        <span class="badge bg-secondary">Archived</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Active</span>
                    }
                </td>
                <td>@p.Color</td>
                <td>@p.CreatedAtUtc.ToString("yyyy-MM-dd")</td>
                <td class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-sm btn-outline-secondary" href="/Projects/Details/@(p.Id)@(wsQ)">Details</a>
                    <a class="btn btn-sm btn-primary" href="/board?projectId=@(p.Id)@(wsAmp)">Board</a>
                    <a class="btn btn-sm btn-outline-info" href="/tasks/list?projectId=@(p.Id)@(wsAmp)">Tasks</a>
                    @if (Model.IsPm)
                    {
                        <a class="btn btn-sm btn-outline-primary" href="/Projects/Settings/@(p.Id)@(wsQ)">Settings</a>
                        <a class="btn btn-sm btn-outline-danger" href="/Projects/Delete/@(p.Id)@(wsQ)">Delete</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
