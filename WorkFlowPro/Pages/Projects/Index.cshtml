@page "/Projects"
@model WorkFlowPro.Pages.Projects.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Projects";
    var wsQ = Model.CurrentWorkspaceId is not null ? $"?workspaceId={Model.CurrentWorkspaceId.Value:D}" : "";
    var wsAmp = Model.CurrentWorkspaceId is not null ? $"&workspaceId={Model.CurrentWorkspaceId.Value:D}" : "";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Projects</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted">
        Workspace Projects
    </div>
    @if (Model.IsPm)
    {
        <a class="btn btn-primary" href="/Projects/Create@(wsQ)">
            + Tạo dự án mới
        </a>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

@if (Model.Projects.Count == 0)
{
    <div class="alert alert-info py-4 text-center">
        <p class="mb-0">Chưa có dự án nào trong workspace hiện tại.</p>
        @if (Model.IsPm)
        {
            <a href="/Projects/Create@(wsQ)" class="btn btn-primary mt-3">
                Tạo dự án đầu tiên
            </a>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tên dự án</th>
                    <th>Trạng thái</th>
                    <th>Màu</th>
                    <th>Ngày tạo</th>
                    <th class="text-end" style="width: 320px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Projects)
                {
                    <tr>
                        <td class="fw-medium">@p.Name</td>
                        <td>
                            @if (p.Status == WorkFlowPro.Data.ProjectStatus.Archived)
                            {
                                <span class="badge bg-secondary">Đã lưu trữ</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.Color))
                            {
                                <span class="badge" style="background-color: @p.Color; color: white;">
                                    @p.Color
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-muted">@p.CreatedAtUtc.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a class="btn btn-outline-secondary"
                                   href="/Projects/Details/@(p.Id)@(wsQ)">Chi tiết</a>
                                
                                <a class="btn btn-primary"
                                   href="/board?projectId=@(p.Id)@(wsAmp)">Board</a>
                                
                                <a class="btn btn-outline-info"
                                   href="/tasks/list?projectId=@(p.Id)@(wsAmp)">Tasks</a>

                                @if (Model.IsPm)
                                {
                                    <a class="btn btn-outline-primary"
                                       href="/Projects/Settings/@(p.Id)@(wsQ)">Cài đặt</a>
                                    
                                    <a class="btn btn-outline-danger"
                                           href="/Projects/Delete/@(p.Id)@(wsQ)"
                                           onclick="return confirm('Bạn có chắc muốn xóa dự án này?');">
                                        Xóa
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}