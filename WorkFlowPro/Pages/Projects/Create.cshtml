@page "/Projects/Create"
@model WorkFlowPro.Pages.Projects.CreateModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create project";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Create Project</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Description" class="form-label"></label>
        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Input.StartDateUtc" class="form-label"></label>
            <input asp-for="Input.StartDateUtc" class="form-control" type="date" />
        </div>
        <div class="col-md-6">
            <label asp-for="Input.EndDateUtc" class="form-label"></label>
            <input asp-for="Input.EndDateUtc" class="form-control" type="date" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Color" class="form-label">Color</label>
        <select asp-for="Input.Color" class="form-select">
            <option value="">-- Chọn màu --</option>
            <option value="#FF6B6B" style="background:#FF6B6B;color:#fff">Đỏ (#FF6B6B)</option>
            <option value="#FFA94D" style="background:#FFA94D;color:#fff">Cam (#FFA94D)</option>
            <option value="#FFD43B" style="background:#FFD43B;color:#333">Vàng (#FFD43B)</option>
            <option value="#69DB7C" style="background:#69DB7C;color:#333">Xanh lá (#69DB7C)</option>
            <option value="#4DABF7" style="background:#4DABF7;color:#fff">Xanh dương (#4DABF7)</option>
            <option value="#9775FA" style="background:#9775FA;color:#fff">Tím (#9775FA)</option>
            <option value="#F06595" style="background:#F06595;color:#fff">Hồng (#F06595)</option>
            <option value="#868E96" style="background:#868E96;color:#fff">Xám (#868E96)</option>
            <option value="#20C997" style="background:#20C997;color:#fff">Ngọc (#20C997)</option>
            <option value="#339AF0" style="background:#339AF0;color:#fff">Biển (#339AF0)</option>
        </select>
        <span asp-validation-for="Input.Color" class="text-danger"></span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning">@Model.ErrorMessage</div>
    }

    <button type="submit" class="btn btn-primary">Create</button>
    <a class="btn btn-outline-secondary"
       href="/Projects@(Model.CurrentWorkspaceId is not null ? $"?workspaceId={Model.CurrentWorkspaceId.Value:D}" : "")">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

