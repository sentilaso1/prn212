@model WorkFlowPro.Pages.Tasks.CommentNodeRenderVm

@{
    var node = Model.Node;
    var canEdit = (Model.CanManageComments || Model.ActorUserId == node.UserId) && !node.IsDeleted;
    var canReply = Model.CanManageComments;
    var canDelete = Model.IsPm || Model.ActorUserId == node.UserId;
}

<div class="mb-3 @(node.ParentCommentId is null ? "" : "ms-4")"
     data-wf-comment-id="@node.Id"
     data-wf-parent-id="@(node.ParentCommentId?.ToString("D") ?? "")"
     data-wf-created-at="@node.CreatedAtUtc.ToString("O")">

    <div class="p-3 border rounded bg-white">
        <div class="d-flex justify-content-between align-items-start gap-2">
            <div>
                <div class="fw-semibold">
                    @node.UserDisplayName
                    @if (node.UpdatedAtUtc is not null)
                    {
                        <span class="text-muted small">(đã chỉnh sửa)</span>
                    }
                </div>
                <div class="text-muted small">@node.CreatedAtUtc.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>

        <div class="mt-2" style="white-space: pre-wrap;" data-wf-comment-content="1">
            @if (node.IsDeleted)
            {
                <em class="text-muted">Bình luận đã bị xóa.</em>
            }
            else
            {
                @node.Content
            }
        </div>

        <div class="mt-3 d-flex gap-3">
            @if (canReply)
            {
                <details>
                    <summary class="small text-primary" style="cursor:pointer;">Trả lời</summary>
                    <form method="post" asp-page-handler="AddComment" data-wf-ajax="true" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="parentCommentId" value="@node.Id" />
                        <textarea class="form-control" name="content" rows="2"></textarea>
                        <button class="btn btn-sm btn-primary mt-2" type="submit">Gửi</button>
                    </form>
                </details>
            }

            @if (canEdit)
            {
                <details>
                    <summary class="small text-primary" style="cursor:pointer;">Chỉnh sửa</summary>
                    <form method="post" asp-page-handler="EditComment" data-wf-ajax="true" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="commentId" value="@node.Id" />
                        <textarea class="form-control" name="content" rows="2">@node.Content</textarea>
                        <button class="btn btn-sm btn-success mt-2" type="submit">Lưu</button>
                    </form>
                </details>
            }

            @if (canDelete)
            {
                <form method="post" asp-page-handler="DeleteComment" data-wf-ajax="true" class="mt-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="commentId" value="@node.Id" />
                    <button class="btn btn-sm btn-outline-danger" type="submit"
                            onclick="return confirm('Xóa bình luận này?');">
                        Xóa
                    </button>
                </form>
            }
        </div>
    </div>

    <div id="wfReplies-@node.Id" class="ms-4">
        @if (node.Replies is not null && node.Replies.Count > 0)
        {
            @foreach (var r in node.Replies)
            {
                <partial name="_CommentNode" model="new WorkFlowPro.Pages.Tasks.CommentNodeRenderVm(r, Model.ActorUserId, Model.CanManageComments, Model.IsPm)" />
            }
        }
    </div>
</div>