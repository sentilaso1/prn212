@page "/tasks/list"
@model WorkFlowPro.Pages.Tasks.TaskListModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Task List";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Task List</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <div class="text-muted">Project</div>
            <div><strong>@Model.ProjectName</strong></div>
            <div class="small mt-1">
                <a href="/board?projectId=@Model.ProjectId">Kanban Board</a>
            </div>
        </div>
    </div>

    <partial name="_TaskFilters" model="Model.Filters" />

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Trạng thái</th>
                    <th>Ưu tiên</th>
                    <th>Hạn</th>
                    <th>Assignee</th>
                </tr>
            </thead>
            <tbody id="wfTaskListBody">
                @foreach (var t in Model.Tasks)
                {
                    var due = t.DueDateUtc?.ToString("yyyy-MM-dd") ?? "-";
                    <tr>
                        <td><a href="/Tasks/Details/@t.TaskId">@t.Title</a></td>
                        <td><span class="badge bg-secondary">@t.Status</span></td>
                        <td>@t.Priority</td>
                        <td>@due</td>
                        <td>@t.AssigneeDisplayName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
@if (Model.ErrorMessage == null && Model.ProjectId != Guid.Empty)
{
    <script src="~/js/task-filters.js" asp-append-version="true"></script>
    <script>
        (function () {
            const projectId = "@Model.ProjectId.ToString("D")";
            const myUserId = "@Model.CurrentUserId";
            const isPm = @(Model.IsPm ? "true" : "false");
            const filterRoot = document.querySelector("[data-project-id=\"" + projectId + "\"][data-view=\"list\"]");
            if (filterRoot && window.wfTaskFilters) {
                window.wfTaskFilters.bindFilterCard(filterRoot, { myUserId: myUserId, isPm: isPm });
            }
        })();
    </script>
}
}
