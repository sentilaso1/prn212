@using WorkFlowPro.Data
@using WorkFlowPro.Services
@using TaskItemStatus = WorkFlowPro.Data.TaskStatus
@model WorkFlowPro.ViewModels.TaskFiltersVm
@{
    var c = Model.Criteria;
    var selAssignees = new HashSet<string>(c.AssigneeUserIds ?? new List<string>(), StringComparer.Ordinal);
    var selStatuses = new HashSet<TaskItemStatus>(c.Statuses ?? new List<TaskItemStatus>());
    var selPri = new HashSet<TaskPriority>(c.Priorities ?? new List<TaskPriority>());
    var formId = $"wfTaskFilters_{Model.ViewContext}_{Model.ProjectId:N}";

    bool St(TaskItemStatus s) => selStatuses.Count == 0 || selStatuses.Contains(s);
    bool Pr(TaskPriority p) => selPri.Count == 0 || selPri.Contains(p);
}

<div class="card mb-4 shadow-sm" id="@formId" 
     data-project-id="@Model.ProjectId" 
     data-view="@Model.ViewContext" 
     data-workspace-id="@(Model.WorkspaceId?.ToString("D") ?? "")">

    <div class="card-header bg-light py-2">
        <strong class="text-muted small">Bộ lọc công việc</strong>
    </div>

    <div class="card-body py-3">
        <div class="row g-3 align-items-end">

            <!-- Assignee -->
            <div class="col-lg-3 col-md-6">
                <label class="form-label small text-muted mb-1">Người thực hiện</label>
                <select class="form-select form-select-sm wf-filter-assignees" multiple size="3" aria-label="Assignee">
                    @foreach (var m in Model.WorkspaceMembers)
                    {
                        <option value="@m.UserId" selected="@selAssignees.Contains(m.UserId)">
                            @m.DisplayName @(m.Level is null ? "" : $"({m.Level})")
                        </option>
                    }
                </select>
                <div class="form-text small">Không chọn = tất cả thành viên</div>
            </div>

            <!-- Trạng thái -->
            <div class="col-lg-3 col-md-6">
                <label class="form-label small text-muted mb-1">Trạng thái</label>
                <div class="border rounded p-2 wf-filter-status" style="max-height: 135px; overflow-y: auto;">
                    <div class="form-check form-check-sm">
                        <input class="form-check-input wf-filter-status-cb" type="checkbox" 
                               value="@TaskItemStatus.Unassigned" id="@(formId)_st_u" checked="@St(TaskItemStatus.Unassigned)" />
                        <label class="form-check-label small" for="@(formId)_st_u">Chưa phân công</label>
                    </div>
                    <div class="form-check form-check-sm">
                        <input class="form-check-input wf-filter-status-cb" type="checkbox" 
                               value="@TaskItemStatus.Pending" id="@(formId)_st_p" checked="@St(TaskItemStatus.Pending)" />
                        <label class="form-check-label small" for="@(formId)_st_p">Đang chờ</label>
                    </div>
                    <div class="form-check form-check-sm">
                        <input class="form-check-input wf-filter-status-cb" type="checkbox" 
                               value="@TaskItemStatus.ToDo" id="@(formId)_st_td" checked="@St(TaskItemStatus.ToDo)" />
                        <label class="form-check-label small" for="@(formId)_st_td">To Do</label>
                    </div>
                    <div class="form-check form-check-sm">
                        <input class="form-check-input wf-filter-status-cb" type="checkbox" 
                               value="@TaskItemStatus.InProgress" id="@(formId)_st_ip" checked="@St(TaskItemStatus.InProgress)" />
                        <label class="form-check-label small" for="@(formId)_st_ip">Đang thực hiện</label>
                    </div>
                    <div class="form-check form-check-sm">
                        <input class="form-check-input wf-filter-status-cb" type="checkbox" 
                               value="@TaskItemStatus.Review" id="@(formId)_st_r" checked="@St(TaskItemStatus.Review)" />
                        <label class="form-check-label small" for="@(formId)_st_r">Review / Testing</label>
                    </div>
                    <div class="form-check form-check-sm">
                        <input class="form-check-input wf-filter-status-cb" type="checkbox" 
                               value="@TaskItemStatus.Done" id="@(formId)_st_d" checked="@St(TaskItemStatus.Done)" />
                        <label class="form-check-label small" for="@(formId)_st_d">Hoàn thành</label>
                    </div>
                    <div class="form-check form-check-sm">
                        <input class="form-check-input wf-filter-status-cb" type="checkbox" 
                               value="@TaskItemStatus.Cancelled" id="@(formId)_st_c" checked="@St(TaskItemStatus.Cancelled)" />
                        <label class="form-check-label small" for="@(formId)_st_c">Đã hủy</label>
                    </div>
                </div>
                <div class="form-text small">Không chọn = tất cả trạng thái (trừ Đã hủy)</div>
            </div>

            <!-- Ưu tiên -->
            <div class="col-lg-2 col-md-4">
                <label class="form-label small text-muted mb-1">Mức ưu tiên</label>
                <div class="wf-filter-priority">
                    @foreach (TaskPriority p in Enum.GetValues<TaskPriority>())
                    {
                        <div class="form-check form-check-sm">
                            <input class="form-check-input wf-filter-pri-cb" type="checkbox" 
                                   value="@p" id="@(formId)_pri_@(p)" checked="@Pr(p)" />
                            <label class="form-check-label small" for="@(formId)_pri_@(p)">@p</label>
                        </div>
                    }
                </div>
                <div class="form-text small">Không chọn = tất cả mức</div>
            </div>

            <!-- Hạn chót -->
            <div class="col-lg-2 col-md-4">
                <label class="form-label small text-muted mb-1">Hạn chót</label>
                <select class="form-select form-select-sm wf-filter-due">
                    <option value="None" selected="@(c.DueDateBucket == TaskDueDateBucket.None)">Tất cả</option>
                    <option value="Today" selected="@(c.DueDateBucket == TaskDueDateBucket.Today)">Hôm nay</option>
                    <option value="ThisWeek" selected="@(c.DueDateBucket == TaskDueDateBucket.ThisWeek)">Tuần này</option>
                    <option value="ThisMonth" selected="@(c.DueDateBucket == TaskDueDateBucket.ThisMonth)">Tháng này</option>
                    <option value="Overdue" selected="@(c.DueDateBucket == TaskDueDateBucket.Overdue)">Quá hạn</option>
                </select>
            </div>

            <!-- Sắp xếp -->
            <div class="col-lg-2 col-md-4">
                <label class="form-label small text-muted mb-1">Sắp xếp theo</label>
                <select class="form-select form-select-sm wf-filter-sort">
                    <option value="DueDateAsc" selected="@(c.Sort == TaskSortOption.DueDateAsc)">Hạn chót ↑</option>
                    <option value="DueDateDesc" selected="@(c.Sort == TaskSortOption.DueDateDesc)">Hạn chót ↓</option>
                    <option value="PriorityAsc" selected="@(c.Sort == TaskSortOption.PriorityAsc)">Ưu tiên ↑</option>
                    <option value="PriorityDesc" selected="@(c.Sort == TaskSortOption.PriorityDesc)">Ưu tiên ↓</option>
                    <option value="CreatedAtAsc" selected="@(c.Sort == TaskSortOption.CreatedAtAsc)">Ngày tạo ↑</option>
                    <option value="CreatedAtDesc" selected="@(c.Sort == TaskSortOption.CreatedAtDesc)">Ngày tạo ↓</option>
                    <option value="TitleAsc" selected="@(c.Sort == TaskSortOption.TitleAsc)">Tiêu đề A → Z</option>
                    <option value="TitleDesc" selected="@(c.Sort == TaskSortOption.TitleDesc)">Tiêu đề Z → A</option>
                </select>
            </div>

            <!-- Nút xóa lọc -->
            <div class="col-lg-1 col-md-4 text-md-end">
                <button type="button" class="btn btn-sm btn-outline-secondary wf-filter-clear mt-4">
                    Xóa bộ lọc
                </button>
            </div>

        </div>
    </div>
</div>