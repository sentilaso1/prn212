@model WorkFlowPro.Pages.Tasks.CommentsVm
@{
    var d = Model.detail;
}

<div class="card shadow-sm">
    <div class="card-header bg-light py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">Bình luận</h5>
            <span class="text-muted small">@Model.items.Count comment(s)</span>
        </div>
    </div>

    <div class="card-body">
        @if (d.CanManageComments)
        {
            <form method="post" asp-page-handler="AddComment" data-wf-ajax="true" class="mb-4">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label small text-muted">Thêm bình luận</label>
                    <textarea class="form-control" name="content" rows="3" placeholder="Viết bình luận của bạn..."></textarea>
                </div>
                <input type="hidden" name="parentCommentId" value="" />
                <button class="btn btn-primary" type="submit">Gửi bình luận</button>
            </form>
        }

        @{
            var anti = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
            var tokens = anti?.GetAndStoreTokens(Context);
            var csrf = tokens?.RequestToken ?? "";
        }

        <div id="wfCommentsRoot"
             data-actor-user-id="@Model.actorUserId"
             data-can-manage="@(d.CanManageComments ? "1" : "0")"
             data-csrf="@csrf">

            <div id="wfCommentsList">
                @if (Model.items.Count == 0)
                {
                    <div class="alert alert-info small text-center py-4">Chưa có bình luận nào.</div>
                }
                else
                {
                    <div class="list-unstyled" id="wfCommentsTree">
                        @foreach (var c in Model.items)
                        {
                            <partial name="_CommentNode" model="new WorkFlowPro.Pages.Tasks.CommentNodeRenderVm(c, Model.actorUserId, d.CanManageComments, d.IsPm)" />
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>