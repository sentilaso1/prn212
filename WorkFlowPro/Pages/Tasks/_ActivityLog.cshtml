@using WorkFlowPro.Services
@model WorkFlowPro.Pages.Tasks.ActivityLogVm

<div class="card shadow-sm">
    <div class="card-header bg-light py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">Lịch sử hoạt động</h5>
            <span class="text-muted small">@Model.items.Count entry(s)</span>
        </div>
    </div>

    <div class="card-body p-0">
        <style>
            .wf-avatar { width: 32px; height: 32px; border-radius: 50%; overflow: hidden; object-fit: cover; }
            .wf-avatar--text { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #e9ecef; color: #495057; font-weight: 700; font-size: 14px; }
            .wf-history-scroll { max-height: 460px; overflow-y: auto; }
            .wf-history-entry-action { white-space: pre-wrap; line-height: 1.4; }
        </style>

        <div id="wfHistoryList" class="wf-history-scroll p-3">
            @if (Model.items.Count == 0)
            {
                <div class="alert alert-info small text-center py-4">Chưa có lịch sử cho task này.</div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var h in Model.items)
                    {
                        <div class="list-group-item py-3">
                            <div class="d-flex gap-3">
                                <div class="flex-shrink-0">
                                    @if (!string.IsNullOrWhiteSpace(h.ActorAvatarUrl))
                                    {
                                        <img src="@h.ActorAvatarUrl" class="wf-avatar" alt="avatar" />
                                    }
                                    else
                                    {
                                        <div class="wf-avatar wf-avatar--text">
                                            @(string.IsNullOrWhiteSpace(h.ActorDisplayName) ? "?" : h.ActorDisplayName[0].ToString().ToUpperInvariant())
                                        </div>
                                    }
                                </div>

                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="fw-semibold">@h.ActorDisplayName</div>
                                        <div class="text-muted small">@TaskHistoryHelper.FormatRelativeTime(h.TimestampUtc)</div>
                                    </div>

                                    <div class="wf-history-entry-action small mt-1 text-muted">
                                        @TaskHistoryHelper.GetHumanReadableAction(h)
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(h.OldValue) || !string.IsNullOrWhiteSpace(h.NewValue))
                                    {
                                        <div class="mt-2 small">
                                            @if (!string.IsNullOrWhiteSpace(h.OldValue))
                                            {
                                                <div class="text-muted">Old: <span class="text-dark">@h.OldValue</span></div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(h.NewValue))
                                            {
                                                <div class="text-muted">New: <span class="text-dark">@h.NewValue</span></div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>