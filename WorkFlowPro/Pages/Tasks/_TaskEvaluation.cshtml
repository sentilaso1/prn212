@using WorkFlowPro.Services
@model WorkFlowPro.Pages.Tasks.EvaluationSectionVm
@{
    var isPm = Model.isPm;
    var status = Model.status;
    var history = Model.evaluations ?? Array.Empty<WorkFlowPro.Services.TaskEvaluationVm>();
    var alreadyLocked = history.Any();
}

@if (!isPm)
{
    <div class="alert alert-secondary">Chỉ PM mới xem được phần đánh giá.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header bg-light py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-semibold">Đánh giá Task</h5>
                <span class="text-muted small">@history.Count evaluation(s)</span>
            </div>
        </div>

        <div class="card-body">
            <style>
                .wf-avatar { width: 32px; height: 32px; border-radius: 50%; overflow: hidden; object-fit: cover; }
                .wf-avatar--text { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #e9ecef; color: #495057; font-weight: 700; font-size: 14px; }
                .wf-eval-history { max-height: 280px; overflow-y: auto; }
            </style>

            @if (status != WorkFlowPro.Data.TaskStatus.Done)
            {
                <div class="alert alert-info mb-3">
                    Chỉ có thể đánh giá khi task ở trạng thái <strong>Done</strong>.
                </div>
            }

            @if (history.Count == 0)
            {
                <div class="alert alert-info mb-3">Chưa có đánh giá nào cho task này.</div>
            }
            else
            {
                <div class="mb-4">
                    <div class="fw-semibold mb-2">Lịch sử đánh giá</div>
                    <div class="list-group wf-eval-history">
                        @foreach (var e in history)
                        {
                            <div class="list-group-item py-3">
                                <div class="d-flex gap-3">
                                    <div class="flex-shrink-0">
                                        @if (!string.IsNullOrWhiteSpace(e.PmAvatarUrl))
                                        {
                                            <img src="@e.PmAvatarUrl" class="wf-avatar" alt="avatar" />
                                        }
                                        else
                                        {
                                            <div class="wf-avatar wf-avatar--text">
                                                @(string.IsNullOrWhiteSpace(e.PmDisplayName) ? "?" : e.PmDisplayName[0].ToString().ToUpperInvariant())
                                            </div>
                                        }
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between">
                                            <div class="fw-semibold">@e.PmDisplayName</div>
                                            <div class="text-muted small">@TaskHistoryHelper.FormatRelativeTime(e.EvaluatedAtUtc)</div>
                                        </div>
                                        <div class="small mt-1">
                                            <strong>Điểm:</strong> @e.Score / 10
                                            @if (e.IsLocked)
                                            {
                                                <span class="badge bg-secondary ms-2">Đã khóa</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(e.Comment))
                                        {
                                            <div class="small mt-2 text-muted" style="white-space: pre-wrap;">@e.Comment</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (status == WorkFlowPro.Data.TaskStatus.Done)
            {
                if (alreadyLocked)
                {
                    <div class="alert alert-secondary mb-0">
                        Task đã được đánh giá và khóa. Không thể đánh giá lại.
                    </div>
                }
                else
                {
                    <form method="post" asp-page-handler="UpsertEvaluation" data-wf-ajax="true">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="taskId" value="@Model.taskId" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Điểm số (1 - 10)</label>
                                <input class="form-control" type="number" name="score" min="1" max="10" value="8" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Cập nhật Level</label>
                                <select class="form-select" name="newLevel">
                                    <option value="">— Tự động theo điểm —</option>
                                    <option value="Junior">Junior</option>
                                    <option value="Mid">Mid</option>
                                    <option value="Senior">Senior</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label">Nhận xét (tùy chọn)</label>
                            <textarea class="form-control" name="comment" rows="3" maxlength="2000"></textarea>
                        </div>

                        <button class="btn btn-primary mt-3" type="submit">Gửi đánh giá</button>
                    </form>
                }
            }
        </div>
    </div>
}