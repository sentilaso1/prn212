@using WorkFlowPro.Services
@model WorkFlowPro.Pages.Tasks.EvaluationSectionVm
@{
    var isPm = Model.isPm;
    var status = Model.status;
    var history = Model.evaluations ?? Array.Empty<WorkFlowPro.Services.TaskEvaluationVm>();
    var latest = history.FirstOrDefault();
}

@if (!isPm)
{
    <div class="alert alert-secondary">Only PM can view evaluation.</div>
}
else
{
    <div class="card card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0">Đánh giá Task (UC-08)</h5>
            <span class="text-muted small">@history.Count evaluation(s)</span>
        </div>

        <style>
            .wf-avatar { width: 32px; height: 32px; border-radius: 50%; overflow: hidden; object-fit: cover; }
            .wf-avatar--text { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #eee; color: #333; font-weight: 700; }
            .wf-eval-history { max-height: 260px; overflow-y: auto; }
        </style>

        @if (status != WorkFlowPro.Data.TaskStatus.Done)
        {
            <div class="alert alert-info mb-3">
                Chỉ đánh giá / sửa đánh giá khi task ở <strong>Done</strong>. Đánh giá đã lưu <strong>không đổi</strong> khi kéo task về trạng thái trước.
            </div>
        }

        @if (history.Count == 0)
        {
            <div class="alert alert-info mb-3">Chưa có evaluation cho task này.</div>
        }
        else
        {
            <div class="mb-3">
                <div class="fw-semibold mb-2">Lịch sử đánh giá</div>
                <div class="list-group wf-eval-history">
                    @foreach (var e in history)
                    {
                        <div class="list-group-item">
                            <div class="d-flex gap-3">
                                <div>
                                    @if (!string.IsNullOrWhiteSpace(e.PmAvatarUrl))
                                    {
                                        <img src="@e.PmAvatarUrl" class="wf-avatar" alt="avatar" />
                                    }
                                    else
                                    {
                                        <div class="wf-avatar wf-avatar--text">
                                            @(string.IsNullOrWhiteSpace(e.PmDisplayName) ? "?" : e.PmDisplayName[0].ToString().ToUpperInvariant())
                                        </div>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div class="fw-semibold">@e.PmDisplayName</div>
                                        <div class="text-muted small">@TaskHistoryHelper.FormatRelativeTime(e.EvaluatedAtUtc)</div>
                                    </div>
                                    <div class="small mt-1">
                                        <strong>Score:</strong> @e.Score / 10
                                        @if (e.IsLocked)
                                        {
                                            <span class="badge bg-secondary ms-2">Locked</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(e.Comment))
                                    {
                                        <div class="small mt-1" style="white-space: pre-wrap;">@e.Comment</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (status == WorkFlowPro.Data.TaskStatus.Done)
        {
            if (Model.canEditEvaluation)
            {
                <form method="post" asp-page-handler="UpsertEvaluation" data-wf-ajax="true">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskId" value="@Model.taskId" />
                    <div class="mb-2">
                        <label class="form-label">Score (1..10)</label>
                        <input class="form-control" type="number" name="score" min="1" max="10" value="@Model.prefillScore" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Comment (optional, max 2000)</label>
                        <textarea class="form-control" name="comment" rows="3" maxlength="2000">@Model.prefillComment</textarea>
                    </div>
                    <button class="btn btn-primary" type="submit">@(latest is null ? "Đánh giá" : "Cập nhật đánh giá (trong 24h)")</button>
                </form>
            }
            else if (latest is not null)
            {
                <div class="alert alert-secondary mb-0">
                    Không thể sửa đánh giá: đã quá <strong>24 giờ</strong> kể từ mốc thời gian đánh giá đang hiển thị.
                </div>
            }
        }
    </div>
}
