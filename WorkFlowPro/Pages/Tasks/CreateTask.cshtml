@page "/Tasks/Create"
@model WorkFlowPro.Pages.Tasks.CreateTaskModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create task";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Create task</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div id="wfCreateTaskRoot" data-workspace-id="@Model.CurrentWorkspaceId">
<form method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger" role="alert"></div>

    <input asp-for="Input.ProjectId" type="hidden" />

    <div class="mb-3">
        <label asp-for="Input.Title" class="form-label"></label>
        <input asp-for="Input.Title" class="form-control" />
        <span asp-validation-for="Input.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Description" class="form-label"></label>
        <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <label asp-for="Input.Priority" class="form-label"></label>
            <select asp-for="Input.Priority" class="form-select">
                <option value="@WorkFlowPro.Data.TaskPriority.Low">Low</option>
                <option value="@WorkFlowPro.Data.TaskPriority.Medium">Medium</option>
                <option value="@WorkFlowPro.Data.TaskPriority.High">High</option>
                <option value="@WorkFlowPro.Data.TaskPriority.Critical">Critical</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.DueDateUtc" class="form-label"></label>
            <input asp-for="Input.DueDateUtc" class="form-control" type="date" />
            <span asp-validation-for="Input.DueDateUtc" class="text-danger"></span>
        </div>
    </div>

    <hr />

    <h5>Smart Suggest Assignee</h5>

    <div id="wfCreateTaskSuggestions">
    @if (Model.SuggestedAssignees.Count == 0)
    {
        <div class="alert alert-info">
            Chưa có member đủ điều kiện để gợi ý phân công.
        </div>
    }
    else
    {
        <div class="mb-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" name="Input.AssigneeUserId" value=""
                       checked="@(string.IsNullOrWhiteSpace(Model.Input.AssigneeUserId) ? "checked" : null)" />
                <label class="form-check-label">
                    Không gán ai (task ở trạng thái Unassigned)
                </label>
            </div>
        </div>

        <table class="table table-sm table-striped">
            <thead>
            <tr>
                <th>Select</th>
                <th>Name</th>
                <th>Level</th>
                <th>Completion Rate</th>
                <th>AvgScore</th>
                <th>CurrentWorkload</th>
            </tr>
            </thead>
            <tbody id="wfSuggestedAssigneesBody">
            @foreach (var s in Model.SuggestedAssignees)
            {
                <tr>
                    <td style="width:90px;">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Input.AssigneeUserId" value="@s.UserId"
                                   checked="@(Model.Input.AssigneeUserId == s.UserId ? "checked" : null)" />
                        </div>
                    </td>
                    <td>@s.DisplayName</td>
                    <td>@s.Level</td>
                    <td>@s.CompletionRate.ToString("P0")</td>
                    <td>@s.AvgScore.ToString("0.0")</td>
                    <td>@s.CurrentWorkload</td>
                </tr>
            }
            </tbody>
        </table>
        <div class="form-text">
            Gợi ý dựa trên `MemberProfile` của member (CurrentWorkload thấp, CompletionRate/AvgScore cao, Level phù hợp).
        </div>
    }
    </div>

    <hr />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" asp-page-handler="Create">Tạo task</button>
        <button type="submit" class="btn btn-outline-primary" asp-page-handler="CreateWithSuggestion">Tạo + Gợi ý phân công</button>
        <a class="btn btn-outline-secondary" href="/Projects">Cancel</a>
    </div>
</form>
</div>

@if (Model.ShowSuccessToast)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="taskSuccessToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @Model.SuccessToastMessage
                    @if (Model.Input.ProjectId != Guid.Empty)
                    {
                        <a class="ms-2" href="/board?projectId=@Model.Input.ProjectId">Xem Kanban</a>
                    }
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (Model.CurrentWorkspaceId is not null && Model.ErrorMessage is null)
    {
        <script src="~/js/create-task-signalr.js" asp-append-version="true"></script>
    }

    @if (Model.ShowSuccessToast)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const el = document.getElementById('taskSuccessToast');
                if (!el) return;
                const toast = new bootstrap.Toast(el, { delay: 4000 });
                toast.show();
            });
        </script>
    }
}

