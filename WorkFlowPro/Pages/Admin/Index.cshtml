@page "/Admin"
@model WorkFlowPro.Pages.Admin.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin — duyệt PM & yêu cầu role";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1 class="h3 mb-4">Quản trị nền tảng</h1>

<p class="mb-3">
    <a class="btn btn-sm btn-outline-secondary" href="/Admin/audit-log">Nhật ký kiểm toán</a>
    <a class="btn btn-sm btn-outline-secondary ms-1" href="/Admin/system-reports">Báo cáo hệ thống</a>
</p>

@if (Model.ShowToast)
{
    <div class="alert alert-info">@Model.ToastMessage</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Đăng ký PM chờ duyệt</div>
    <div class="card-body p-0">
        @if (Model.PendingRegistrations.Count == 0)
        {
            <p class="text-muted p-3 mb-0">Không có yêu cầu nào.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                    <tr>
                        <th>Email</th>
                        <th>Tên hiển thị</th>
                        <th>Đơn vị dự kiến</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @{ var regIdx = 0; }
                    @foreach (var r in Model.PendingRegistrations)
                    {
                        regIdx++;
                        <tr>
                            <td>@r.Email</td>
                            <td>@(r.DisplayName ?? "—")</td>
                            <td>@(r.PendingWorkspaceName ?? "—")</td>
                            <td class="text-end text-nowrap">
                                <form method="post" asp-page-handler="ApproveRegistration" class="d-inline">
                                    <input type="hidden" name="targetUserId" value="@r.UserId" />
                                    <button type="submit" class="btn btn-sm btn-success">Duyệt & Gán đơn vị</button>
                                </form>
                                <button type="button" class="btn btn-sm btn-outline-danger ms-1"
                                        data-bs-toggle="modal" data-bs-target="#modalRejectPm_@regIdx">Từ chối</button>
                                <div class="modal fade" id="modalRejectPm_@regIdx" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content text-start">
                                            <form method="post" asp-page-handler="RejectRegistration">
                                                <div class="modal-header">
                                                    <h6 class="modal-title">Từ chối đăng ký PM: @r.Email</h6>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <input type="hidden" name="targetUserId" value="@r.UserId" />
                                                    <label class="form-label small">Lý do từ chối <span class="text-danger">*</span></label>
                                                    <textarea name="reason" class="form-control" rows="3" maxlength="500" required placeholder="Bắt buộc, tối đa 500 ký tự"></textarea>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn btn-sm btn-danger">Xác nhận từ chối</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Đề xuất đổi level</div>
    <div class="card-body p-0">
        @if (Model.PendingLevelAdjustments.Count == 0)
        {
            <p class="text-muted p-3 mb-0">Không có yêu cầu nào.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead>
                    <tr>
                        <th>Thành viên</th>
                        <th>Đơn vị</th>
                        <th>Level hiện tại</th>
                        <th>Đề xuất</th>
                        <th>PM gửi</th>
                        <th>Completion %</th>
                        <th>Avg score</th>
                        <th>Luận cứ</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @{ var laIdx = 0; }
                    @foreach (var a in Model.PendingLevelAdjustments)
                    {
                        laIdx++;
                        <tr>
                            <td>@a.TargetDisplayName</td>
                            <td>@a.WorkspaceName</td>
                            <td>@a.CurrentLevel</td>
                            <td>@a.ProposedLevel</td>
                            <td>@a.RequesterDisplayName</td>
                            <td>@a.CompletionRate.ToString("P0")</td>
                            <td>@a.AvgScore.ToString("0.##")</td>
                            <td class="small">@a.Reason</td>
                            <td class="text-end text-nowrap">
                                <form method="post" asp-page-handler="ApproveLevelAdjustment" class="d-inline">
                                    <input type="hidden" name="requestId" value="@a.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                </form>
                                <button type="button" class="btn btn-sm btn-outline-danger ms-1"
                                        data-bs-toggle="modal" data-bs-target="#modalRejectLevel_@laIdx">Từ chối</button>
                                <div class="modal fade" id="modalRejectLevel_@laIdx" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content text-start">
                                            <form method="post" asp-page-handler="RejectLevelAdjustment">
                                                <div class="modal-header">
                                                    <h6 class="modal-title">Từ chối đề xuất level — @a.TargetDisplayName</h6>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <input type="hidden" name="requestId" value="@a.Id" />
                                                    <label class="form-label small">Lý do từ chối <span class="text-danger">*</span></label>
                                                    <textarea name="reason" class="form-control" rows="3" maxlength="500" required></textarea>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn btn-sm btn-danger">Xác nhận</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Dự án chờ duyệt</div>
    <div class="card-body p-0">
        @if (Model.PendingProjects.Count == 0)
        {
            <p class="text-muted p-3 mb-0">Không có dự án nào chờ duyệt.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                    <tr>
                        <th>Tên dự án</th>
                        <th>Đơn vị</th>
                        <th>Người tạo</th>
                        <th>Mô tả</th>
                        <th>Ngày tạo</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var p in Model.PendingProjects)
                    {
                        <tr>
                            <td>@p.ProjectName</td>
                            <td>@p.WorkspaceName</td>
                            <td>@p.OwnerDisplayName</td>
                            <td class="small">@(p.Description ?? "—")</td>
                            <td>@p.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-end text-nowrap">
                                <form method="post" asp-page-handler="ApproveProject" class="d-inline">
                                    <input type="hidden" name="projectId" value="@p.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                </form>
                                <button type="button" class="btn btn-sm btn-outline-danger ms-1"
                                        data-bs-toggle="modal" data-bs-target="#modalRejectProject_@p.Id">Từ chối</button>

                                <div class="modal fade" id="modalRejectProject_@p.Id" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content text-start">
                                            <form method="post" asp-page-handler="RejectProject">
                                                <div class="modal-header">
                                                    <h6 class="modal-title">Từ chối dự án: @p.ProjectName</h6>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <input type="hidden" name="projectId" value="@p.Id" />
                                                    <label class="form-label small">Lý do từ chối <span class="text-danger">*</span></label>
                                                    <textarea name="reason" class="form-control" rows="3" maxlength="500" required></textarea>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Hủy</button>
                                                    <button type="submit" class="btn btn-sm btn-danger">Xác nhận từ chối</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Yêu cầu nâng / hạ / xóa PM trong đơn vị</div>
    <div class="card-body p-0">
        @if (Model.PendingRoleRequests.Count == 0)
        {
            <p class="text-muted p-3 mb-0">Không có yêu cầu nào.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                    <tr>
                        <th>Id</th>
                        <th>Đơn vị</th>
                        <th>Loại</th>
                        <th>Đối tượng</th>
                        <th>Người gửi</th>
                        <th>Lý do</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in Model.PendingRoleRequests)
                    {
                        var kindLabel = r.Kind switch
                        {
                            WorkFlowPro.Data.WorkspaceRoleRequestKind.PromoteMemberToPm => "Nâng → PM",
                            WorkFlowPro.Data.WorkspaceRoleRequestKind.DemotePmToMember => "Hạ PM → Member",
                            WorkFlowPro.Data.WorkspaceRoleRequestKind.RemovePmFromWorkspace => "Xóa PM khỏi đơn vị",
                            _ => r.Kind.ToString()
                        };
                        <tr>
                            <td>@r.Id</td>
                            <td>@r.WorkspaceName</td>
                            <td>@kindLabel</td>
                            <td>@r.TargetDisplay</td>
                            <td>@r.RequesterDisplay</td>
                            <td class="small">@(r.Reason ?? "—")</td>
                            <td class="text-end text-nowrap">
                                <form method="post" asp-page-handler="ApproveRoleRequest" class="d-inline">
                                    <input type="hidden" name="requestId" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                </form>
                                <form method="post" asp-page-handler="RejectRoleRequest" class="d-inline ms-1">
                                    <input type="hidden" name="requestId" value="@r.Id" />
                                    <input type="text" name="adminNote" class="form-control form-control-sm d-inline-block" style="width:120px;" placeholder="Ghi chú" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Từ chối</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Hạ PM trực tiếp</div>
    <div class="card-body">
        @if (Model.AllWorkspaces.Count == 0)
        {
            <p class="text-muted small">Chưa có đơn vị nào trong hệ thống.</p>
        }
        else
        {
            <form method="get" class="row g-2 align-items-end mb-3">
                <div class="col-auto">
                    <label class="form-label small mb-0">Đơn vị</label>
                    <select name="DemoteWorkspaceId" class="form-select form-select-sm" onchange="this.form.submit()">
                        @foreach (var w in Model.AllWorkspaces)
                        {
                            if (Model.DemoteWorkspaceId == w.Id)
                            {
                                <option value="@w.Id" selected>@w.Name</option>
                            }
                            else
                            {
                                <option value="@w.Id">@w.Name</option>
                            }
                        }
                    </select>
                </div>
            </form>
        }

        @if (Model.AllWorkspaces.Count > 0)
        {
            @if (Model.PmsInSelectedWorkspace.Count == 0)
            {
                <p class="text-muted small mb-0">Không có PM trong đơn vị này.</p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @{ var demIdx = 0; }
                    @foreach (var p in Model.PmsInSelectedWorkspace)
                    {
                        demIdx++;
                        <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <span>@p.DisplayName <span class="text-muted small">(@p.Email)</span></span>
                            <button type="button" class="btn btn-sm btn-outline-warning"
                                    data-bs-toggle="modal" data-bs-target="#modalDemotePm_@demIdx">Hạ xuống Member</button>
                            <div class="modal fade" id="modalDemotePm_@demIdx" tabindex="-1">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content text-start">
                                        <form method="post" asp-page-handler="DemotePmDirect">
                                            <div class="modal-header">
                                                <h6 class="modal-title">Hạ PM → Member: @p.DisplayName</h6>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <input type="hidden" name="workspaceId" value="@Model.DemoteWorkspaceId" />
                                                <input type="hidden" name="targetUserId" value="@p.UserId" />
                                                <label class="form-label small">Lý do <span class="text-danger">*</span></label>
                                                <textarea name="reason" class="form-control" rows="3" maxlength="500" required placeholder="Bắt buộc nhập lý do"></textarea>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Hủy</button>
                                                <button type="submit" class="btn btn-sm btn-warning">Xác nhận hạ</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
        }
    </div>
</div>

<p class="small text-muted mb-0">Giới hạn: <strong>@WorkFlowPro.Data.WorkspacePolicies.MaxPmsPerWorkspace</strong> PM trên mỗi đơn vị.</p>
