@page "/Workspaces"
@model WorkFlowPro.Pages.Workspaces.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Workspaces";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Your Workspaces</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-warning">
        @Model.ErrorMessage
    </div>
}

@if (Model.Workspaces.Count == 0)
{
    <div class="alert alert-warning">
        No workspace found. If you just registered, please try again.
    </div>
}
else
{
    <p>
        Active workspace:
        <strong>@(Model.ActiveWorkspaceId?.ToString() ?? "-")</strong>
    </p>

    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Role</th>
            <th style="width:1%; white-space:nowrap;">Id</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var w in Model.Workspaces)
        {
            <tr>
                <td>@w.Name @(w.Id == Model.ActiveWorkspaceId ? "(Active)" : "")</td>
                <td>@w.Role</td>
                <td>@w.Id</td>
            </tr>
        }
        </tbody>
    </table>
}

