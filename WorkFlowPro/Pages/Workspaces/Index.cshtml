@page "/Workspaces"
@model WorkFlowPro.Pages.Workspaces.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đơn vị của tôi";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1 class="h3 mb-3">Đơn vị (workspace) của bạn</h1>

@if (Model.InfoMessage is not null)
{
    <div class="alert alert-info">
        @Model.InfoMessage
    </div>
}

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-warning">
        @Model.ErrorMessage
    </div>
}

@if (Model.Workspaces.Count == 0)
{
    <div class="alert alert-info">
        <p class="mb-2"><strong>Bạn chưa thuộc đơn vị nào.</strong></p>
        <p class="mb-0 small">
            Hãy chờ PM gửi <strong>lời mời</strong> (UC-03) và chấp nhận qua thông báo hoặc link mời.
            Nếu bạn đăng ký vai trò <strong>PM</strong>, cần chờ Admin nền tảng duyệt trước khi có đơn vị.
        </p>
    </div>
}
else
{
    <p class="text-muted small">
        Đơn vị đang chọn: <strong>@(Model.ActiveWorkspaceId?.ToString() ?? "-")</strong>
    </p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Tên đơn vị</th>
                <th>Vai trò</th>
                <th style="min-width: 160px;">Quản lý dự án</th>
                <th style="width:1%; white-space:nowrap;">Id</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var w in Model.Workspaces)
            {
                <tr>
                    <td>
                        <a href="/Workspaces/Switch?workspaceId=@w.Id&returnUrl=@Uri.EscapeDataString("/Workspaces")">@w.Name</a>
                        @(w.Id == Model.ActiveWorkspaceId ? " (đang chọn)" : "")
                    </td>
                    <td class="align-middle">@w.Role</td>
                    <td class="align-middle">
                        @if (w.IsWorkspacePm)
                        {
                            <a class="btn btn-sm btn-primary"
                               href="/Projects?workspaceId=@w.Id.ToString("D")"
                               title="Danh sách dự án — tạo task theo dự án (UC-04 / UC-12)">
                                Quản lý dự án
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="small">@w.Id</td>
                </tr>
            }
        </tbody>
    </table>
}