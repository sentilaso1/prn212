<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkFlowPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkFlowPro.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">WorkFlowPro</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-sm-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-sm-center gap-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <partial name="_NotificationBell" />
                            @await Component.InvokeAsync("WorkspaceSwitcher")
                            <li class="nav-item">
                                <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" method="post">
                                    <button type="submit" class="btn btn-link nav-link text-dark py-0 px-2">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Identity/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-semibold" href="/Identity/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_NotificationToast" />
    }
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WorkFlowPro - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script src="~/js/notifications.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <script>
    // Fix workspace switch: always redirect to /Workspaces after switching
    // to avoid AccessDenied when leaving PM-only pages as Member.
    (function(){
        var form = document.querySelector('form[action="/Workspaces/Switch"]');
        if (!form) return;
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var sel = form.querySelector('select[name="workspaceId"]');
            if (!sel || !sel.value) return;
            window.location.href = '/Workspaces/Switch?workspaceId=' + sel.value + '&returnUrl=%2FWorkspaces';
        });
        var sel = form.querySelector('select[name="workspaceId"]');
        if (sel) {
            sel.removeAttribute('onchange');
            sel.addEventListener('change', function() {
                if (!this.value) return;
                window.location.href = '/Workspaces/Switch?workspaceId=' + this.value + '&returnUrl=%2FWorkspaces';
            });
        }
    })();
    </script>
</body>
</html>