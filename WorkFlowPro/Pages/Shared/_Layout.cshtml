<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkFlowPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkFlowPro.styles.css" asp-append-version="true" />

    <!-- Optional: Font Awesome cho icon (nếu chưa có) -->
    <!-- <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" /> -->
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom mb-4">
            <div class="container">
                <!-- Logo -->
                <a class="navbar-brand fw-bold text-primary d-flex align-items-center" asp-area="" asp-page="/Index">
                    <span class="me-2">📋</span> WorkFlowPro
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav flex-grow-1 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Trang chủ</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Workspaces">Đơn vị</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Tasks/MyTasks/Pending">Việc chờ xử lý</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/tasks">Danh sách task</a>
                            </li>
                            <li class="nav-item">
                                @using Microsoft.AspNetCore.Http
                                @{
                                    var wsId = ViewContext.HttpContext.Session.GetString("CurrentWorkspaceId");
                                    var profileUrl = string.IsNullOrEmpty(wsId) ? "/Profile" : $"/Profile?workspaceId={wsId}";
                                }
                                <a class="nav-link" href="@profileUrl">Hồ sơ của tôi</a>
                            </li>
                        }
                    </ul>

                    <!-- Phần bên phải -->
                    <ul class="navbar-nav align-items-lg-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var currentWorkspaceId = (ViewContext.ViewData["CurrentWorkspaceId"] as Guid?) 
                                ?? (ViewContext.HttpContext.Items["CurrentWorkspaceId"] as Guid?);
                            
                            <!-- Notification -->
                            <partial name="_NotificationBell" />

                            <!-- Workspace Switcher -->
                            @await Component.InvokeAsync("WorkspaceSwitcher")

                            <!-- Logout -->
                            <li class="nav-item">
                                <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" method="post">
                                    <button type="submit" class="btn btn-outline-danger btn-sm px-3">
                                        <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Identity/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary text-white px-4 fw-semibold"
                                   href="/Identity/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Notification Toast chỉ hiển thị khi đã đăng nhập -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_NotificationToast" />
    }

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-light py-4 mt-5">
        <div class="container text-center text-muted small">
            &copy; 2026 WorkFlowPro. All rights reserved.
            <span class="mx-3">•</span>
            <a asp-area="" asp-page="/Privacy" class="text-muted">Chính sách bảo mật</a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script src="~/js/notifications.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <script>
    // Fix workspace switch: always redirect to /Workspaces after switching
    // to avoid AccessDenied when leaving PM-only pages as Member.
    (function(){
        var form = document.querySelector('form[action="/Workspaces/Switch"]');
        if (!form) return;
        form.addEventListener('submit', function(e) {
        e.preventDefault();
            var sel = form.querySelector('select[name="workspaceId"]');
            if (!sel || !sel.value) return;
            window.location.href = '/Workspaces/Switch?workspaceId=' + sel.value + '&returnUrl=%2FWorkspaces';
        });
        var sel = form.querySelector('select[name="workspaceId"]');
        if (sel) {
            sel.removeAttribute('onchange');
            sel.addEventListener('change', function() {
                if (!this.value) return;
                window.location.href = '/Workspaces/Switch?workspaceId=' + this.value + '&returnUrl=%2FWorkspaces';
        });
        }
        })();
    </script>
</body>
</html>