@model IReadOnlyList<WorkFlowPro.ViewModels.ProfileTaskHistoryRowVm>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Lịch sử task (30 ngày gần nhất)</span>
    </div>
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <p class="text-muted p-3 mb-0">Không có task nào trong khoảng thời gian này.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Due date</th>
                        <th>Score</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td>@t.Title</td>
                            <td>@t.Status</td>
                            <td>@(t.DueDateUtc.HasValue ? t.DueDateUtc.Value.ToString("yyyy-MM-dd") : "—")</td>
                            <td>@(t.Score.HasValue ? t.Score.Value.ToString() : "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
