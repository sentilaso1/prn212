@model WorkFlowPro.ViewModels.MemberProfilePageVm

<div class="card shadow-sm mb-4">
    <div class="card-header">Chỉ số hiệu suất</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3 col-6">
                <div class="text-muted small">Level</div>
                <div class="fs-5 fw-semibold">@Model.Level</div>
            </div>
            <div class="col-md-3 col-6">
                <div class="text-muted small">Completion rate</div>
                <div class="fs-5 fw-semibold">@Model.CompletionRate.ToString("P0")</div>
            </div>
            <div class="col-md-3 col-6">
                <div class="text-muted small">Average score</div>
                <div class="fs-5 fw-semibold">@Model.AvgScore.ToString("0.0") <span class="text-muted small">/ 10</span></div>
            </div>
            <div class="col-md-3 col-6">
                <div class="text-muted small">Current workload</div>
                <div class="fs-5 fw-semibold">@Model.CurrentWorkload</div>
            </div>
        </div>
    </div>
</div>
