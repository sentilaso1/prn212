@page "/Identity/Account/ForgotPassword"
@model WorkFlowPro.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Forgot password";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Forgot password</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Send reset link</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-info mt-3">@Model.StatusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.DevResetLink))
        {
            <div class="alert alert-warning mt-3">
                Dev reset link (only for debugging):<br />
                <a href="@Model.DevResetLink">@Model.DevResetLink</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

