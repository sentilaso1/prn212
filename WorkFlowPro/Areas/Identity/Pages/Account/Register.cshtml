@page
@model WorkFlowPro.Areas.Identity.Pages.Account.RegisterModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Create account";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<style>
    .register-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .register-card {
        width: 100%;
        max-width: 440px;
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
        overflow: hidden;
    }

    .register-card-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        padding: 1.75rem 2rem;
        text-align: center;
    }

    .register-card-header .app-icon {
        width: 52px;
        height: 52px;
        background: rgba(255,255,255,0.2);
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.875rem;
    }

    .register-card-header h4 {
        color: #fff;
        font-weight: 700;
        margin: 0;
        font-size: 1.3rem;
    }

    .register-card-header p {
        color: rgba(255,255,255,0.8);
        margin: 0.25rem 0 0;
        font-size: 0.875rem;
    }

    .register-card-body {
        padding: 2rem;
        background: #fff;
    }

    .form-floating .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
    }

    .btn-register {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        border: none;
        border-radius: 10px;
        padding: 0.75rem;
        font-weight: 600;
        font-size: 1rem;
        transition: opacity 0.2s;
    }

    .btn-register:hover {
        opacity: 0.9;
    }

    .divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #adb5bd;
        font-size: 0.8rem;
    }

    .divider::before, .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e9ecef;
    }

    .password-hint {
        font-size: 0.75rem;
        color: #6c757d;
        margin-top: 0.25rem;
    }

    .input-password-wrapper {
        position: relative;
    }

    .input-password-wrapper .form-control {
        padding-right: 3rem;
    }

    .btn-toggle-pw {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        padding: 0;
        color: #6c757d;
        cursor: pointer;
        z-index: 10;
        line-height: 1;
    }

    .btn-toggle-pw:hover {
        color: #0d6efd;
    }
</style>

<div class="register-wrapper">
    <div class="register-card card">
        <div class="register-card-header">
            <div class="app-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="white" viewBox="0 0 16 16">
                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                </svg>
            </div>
            <h4>Đăng ký</h4>
            <p>User thường (@@gmail.com) hoặc PM (chờ Admin duyệt đơn vị)</p>
        </div>

        <div class="register-card-body">
            <div class="alert alert-light border small mb-3 text-start" role="note">
                <strong>User thường:</strong> chỉ email <strong>@@gmail.com</strong> — vào app ngay, chưa có đơn vị cho đến khi được mời.<br />
                <strong>PM:</strong> mọi domain email — tài khoản chờ Admin duyệt, sau đó hệ thống tạo <strong>đơn vị</strong> và gán bạn làm PM.
            </div>
            <form id="registerForm" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show py-2 mb-3" role="alert">
                        <div asp-validation-summary="All" class="mb-0" style="font-size:0.875rem;"></div>
                        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Loại tài khoản</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Input.AccountType" value="@((int)WorkFlowPro.Areas.Identity.Pages.Account.RegistrationAccountType.NormalUser)" id="accNormal" />
                        <label class="form-check-label" for="accNormal">User thường (chỉ @@gmail.com)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Input.AccountType" value="@((int)WorkFlowPro.Areas.Identity.Pages.Account.RegistrationAccountType.RequestPmWorkspace)" id="accPm" />
                        <label class="form-check-label" for="accPm">PM — tạo đơn vị sau khi Admin duyệt</label>
                    </div>
                    <span asp-validation-for="Input.AccountType" class="text-danger small"></span>
                </div>

                <div id="pmWorkspaceFields" class="form-floating mb-3" style="display:none;">
                    <input asp-for="Input.WorkspaceOrCompanyName" class="form-control" autocomplete="organization" placeholder="Tên đơn vị" />
                    <label asp-for="Input.WorkspaceOrCompanyName">Tên đơn vị / công ty</label>
                    <span asp-validation-for="Input.WorkspaceOrCompanyName" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.FullName" class="form-control" autocomplete="name" placeholder="Họ tên hiển thị" />
                    <label asp-for="Input.FullName">Họ tên hiển thị <span class="text-muted">(tùy chọn)</span></label>
                </div>

                <div class="input-password-wrapper mb-1">
                    <div class="form-floating">
                        <input asp-for="Input.Password" id="pw1" class="form-control" autocomplete="new-password" placeholder="Password" />
                        <label asp-for="Input.Password">Password</label>
                    </div>
                    <button type="button" class="btn-toggle-pw" onclick="togglePw('pw1', this)" tabindex="-1">
                        <svg id="eye-pw1" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                        </svg>
                    </button>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <p class="password-hint mb-3">Min. 8 characters, 1 uppercase, 1 number</p>

                <div class="input-password-wrapper mb-4">
                    <div class="form-floating">
                        <input asp-for="Input.ConfirmPassword" id="pw2" class="form-control" autocomplete="new-password" placeholder="Confirm password" />
                        <label asp-for="Input.ConfirmPassword">Confirm password</label>
                    </div>
                    <button type="button" class="btn-toggle-pw" onclick="togglePw('pw2', this)" tabindex="-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                        </svg>
                    </button>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-register w-100">
                    Create account
                </button>

                <div class="divider mt-4">or</div>

                <div class="text-center mt-3">
                    <span class="text-muted small">Already have an account?</span>
                    <a href="/Identity/Account/Login" class="text-decoration-none small fw-semibold ms-1">Sign in</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const pm = @((int)WorkFlowPro.Areas.Identity.Pages.Account.RegistrationAccountType.RequestPmWorkspace);
            const fields = document.getElementById('pmWorkspaceFields');
            const radios = document.querySelectorAll('input[name="Input.AccountType"]');
            function sync() {
                const v = document.querySelector('input[name="Input.AccountType"]:checked');
                if (!fields) return;
                fields.style.display = (v && parseInt(v.value, 10) === pm) ? 'block' : 'none';
            }
            radios.forEach(r => r.addEventListener('change', sync));
            sync();
        })();

        function togglePw(inputId, btn) {
            const input = document.getElementById(inputId);
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.innerHTML = isHidden
                ? `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/>
                    <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
                    <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.708zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/>
                   </svg>`
                : `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                   </svg>`;
        }
    </script>
}
